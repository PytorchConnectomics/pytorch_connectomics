-    pred_fg = pred[fg].ravel()
-
-    # One-pass co-occurrence: (gt_id, pred_id) → overlap count
-    pairs = np.stack([gt_fg, pred_fg], axis=1)
-    unique_pairs, pair_counts = np.unique(pairs, axis=0, return_counts=True)
-
-    # Segment sizes
